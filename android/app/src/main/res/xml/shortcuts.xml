<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    
    <shortcut
        android:shortcutId="connect_work_server"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/connect_label"
        android:shortcutLongLabel="@string/connect_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.adguard.trusttunnel"
            android:targetClass="com.adguard.trusttunnel.MainActivity">
            <!-- This line is REQUIRED for Flutter to know what to do -->
            <extra android:name="type" android:value="connect_work_server" />
        </intent>
    </shortcut>

    <shortcut
        android:shortcutId="disconnect_vpn"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/disconnect_label"
        android:shortcutLongLabel="@string/disconnect_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.adguard.trusttunnel"
            android:targetClass="com.adguard.trusttunnel.MainActivity">
            <extra android:name="type" android:value="disconnect_vpn" />
        </intent>
    </shortcut>

    <shortcut
        android:shortcutId="toggle_vpn"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/toggle_label"
        android:shortcutLongLabel="@string/toggle_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.adguard.trusttunnel"
            android:targetClass="com.adguard.trusttunnel.MainActivity">
            <extra android:name="type" android:value="toggle_vpn" />
        </intent>
    </shortcut>

</shortcuts>
